from flask import Flask, render_template, request, redirect, url_for, flash
from datetime import datetime
import pandas as pd
import matplotlib
matplotlib.use('Agg')  # Non-GUI backend to fix threading issue
import matplotlib.pyplot as plt
import seaborn as sns
import io
import base64
from collections import Counter, defaultdict
from sklearn.linear_model import LinearRegression
import numpy as np

app = Flask(__name__)
app.secret_key = 'super-secret-key-change-in-production'

products = [
    {"id": 1, "name": "Laptop", "stock": 25, "price": 999.99},
    {"id": 2, "name": "Mouse", "stock": 100, "price": 19.99},
    {"id": 3, "name": "Keyboard", "stock": 75, "price": 59.99}
]

sales = []

def get_ml_predictions(sales_list):
    """
    ML Demand Prediction using Linear Regression.
    Simple explanation:
    - Groups sales by day (using date from timestamp)
    - X = day_index (0,1,2...)
    - y = total_qty_sold that day
    - Train LinearRegression: learns trend line
    - Predict next 30 days, sum for total predicted demand
    - Rule-based was simple avg, ML learns from trend.
    """
    if len(sales_list) < 2:
        return 0, [], [], []

    # Parse timestamps to dates, aggregate daily total qty
    daily_sales = defaultdict(int)
    for sale in sales_list:
        date_str = sale['timestamp'][:10]  # YYYY-MM-DD
        daily_sales[date_str] += sale['qty']

    if len(daily_sales) < 2:
        return 0, [], [], []

    dates = sorted(daily_sales.keys())
    day_index = np.array(range(len(dates))).reshape(-1, 1)
    daily_qty = np.array([daily_sales[d] for d in dates]).reshape(-1, 1)

    # Train model
    model = LinearRegression()
    model.fit(day_index, daily_qty)

    # Predict next 30 days
    future_days = np.array(range(len(dates), len(dates)+30)).reshape(-1, 1)
    pred_qty = model.predict(future_days)
    pred_qty = np.maximum(0, pred_qty).flatten()  # No negative
    total_pred = int(np.sum(pred_qty))

    # Actual trend (past daily)
    actual_trend = [int(daily_sales[d]) for d in dates]

    # Forecast (future daily)
    forecast = pred_qty.tolist()

    # Comparison: list of dicts for table {'day': str, 'actual': int or None, 'predicted': int or None}
    comparison = []
    for i in range(max(len(actual_trend), 30)):
        day_label = f"Day {i+1}"
        act = actual_trend[i] if i < len(actual_trend) else None
        pred = forecast[i] if i >= len(actual_trend) else None
        comparison.append({'day': day_label, 'actual': act, 'predicted': pred})

    return total_pred, actual_trend, forecast, comparison

@app.route('/stats')
def stats():
    total_sales = len(sales)
    total_revenue = sum(s['total'] for s in sales) if sales else 0.0
    return {'total_sales': total_sales, 'total_revenue': total_revenue}

@app.route('/')
def index():
    stats_data = stats()
    return render_template('index.html', stats=stats_data)

@app.route('/dashboard')
def dashboard():
    total_products = len(products)
    total_sales = len(sales)
    
    insights = ["📈 Record some sales to see research insights!"]
    chart_url = None
    fastest_product = "N/A"
    dead_stock = "None"
    stock_recommendation = 0
    predicted_demand = 0
    
    ml_predicted_demand = 0
    ml_actual_trend = []
    ml_forecast = []
    ml_comparison = []
    
    # Pandas analysis if sales exist
    if sales:
        sales_df = pd.DataFrame(sales)
        products_df = pd.DataFrame(products)
        sales_df = sales_df.merge(products_df, left_on='product_id', right_on='id', suffixes=('', '_prod'))
        
        # 1. Fastest selling
        product_sales = sales_df.groupby('name')['qty'].sum().sort_values(ascending=False)
        fastest_product = product_sales.index[0] if len(product_sales) > 0 else "N/A"
        fastest_qty = product_sales.iloc[0] if len(product_sales) > 0 else 0
        
        # 2. Dead stock
        dead_stock_list = [p['name'] for p in products if p['stock'] == 0]
        dead_stock = ', '.join(dead_stock_list) if dead_stock_list else 'None'
        
        # 3. Classification & avg
        avg_sales = sales_df.groupby('name')['qty'].mean().round(1)
        slow_products = avg_sales[avg_sales < avg_sales.mean() * 0.5].index.tolist() if len(avg_sales) > 0 else []
        
        # 4. Stock recommendation
        if sales:
            days_since_start = (datetime.now() - datetime.strptime(sales[0]['timestamp'], '%Y-%m-%d %H:%M:%S')).days + 1
            avg_daily_total = len(sales) / days_since_start if days_since_start > 0 else 0
            stock_recommendation = int(avg_daily_total * 30)
        else:
            stock_recommendation = 0
        
        # 5. Insights
        insights = []
        insights.append(f"🔥 {fastest_product} is fastest selling ({int(fastest_qty)} units)")
        if slow_products:
            insights.append(f"🐌 {', '.join(slow_products[:2])} are slow-moving")
        if dead_stock_list:
            insights.append(f"💀 {dead_stock}")
        insights.append(f"📊 Rec stock 30 days: {stock_recommendation} units")
        
        # ML Prediction
        ml_predicted_demand, ml_actual_trend, ml_forecast, ml_comparison = get_ml_predictions(sales)
        predicted_demand = ml_predicted_demand  # Alias for existing template
        
        # 7. Improved Chart: Actual + Predicted trend
        plt.figure(figsize=(12, 6))
        if ml_actual_trend:
            plt.plot(range(1, len(ml_actual_trend)+1), ml_actual_trend, 'o-', label='Actual Daily Sales', color='blue', linewidth=2)
        if ml_forecast:
            future_x = list(range(len(ml_actual_trend)+1, len(ml_actual_trend)+31))
            plt.plot(future_x, ml_forecast, '--', label='ML Predicted (30 days)', color='red', linewidth=2)
        plt.title('ML Demand Prediction: Actual vs Forecast', fontweight='bold', fontsize=14)
        plt.xlabel('Days')
        plt.ylabel('Daily Qty Sold')
        plt.legend()
        plt.grid(True, alpha=0.3)
        plt.tight_layout()
        
        img = io.BytesIO()
        plt.savefig(img, format='png', bbox_inches='tight', dpi=100)
        img.seek(0)
        chart_url = base64.b64encode(img.getvalue()).decode()
        plt.close()
    
    return render_template('dashboard.html', analytics={
        'total_products': total_products,
        'total_sales': total_sales,
        'fastest_product': fastest_product,
        'dead_stock': dead_stock,
        'insights': insights,
        'chart_url': chart_url,
        'stock_recommendation': stock_recommendation,
        'predicted_demand': predicted_demand,
        'ml_predicted_demand': ml_predicted_demand,
        'ml_actual_trend': ml_actual_trend,
        'ml_forecast': ml_forecast,
        'ml_comparison': ml_comparison
    })

@app.route('/products')
def list_products():
    product_total_sold = Counter()
    for s in sales:
        product_total_sold[s['product_id']] += s['qty']
    
    days_left = {}
    for product in products:
        total_sold = product_total_sold[product['id']]
        if total_sold > 0:
            days_left[product['id']] = round(product['stock'] / total_sold * 30, 1) if product['stock'] > 0 else 0
        else:
            days_left[product['id']] = '∞'
    
    return render_template('products.html', products=products, days_left=days_left)

@app.route('/add_product', methods=['POST'])
def add_product():
    name = request.form['name']
    stock = int(request.form['stock'])
    price = float(request.form['price'])
    new_id = max(p['id'] for p in products) + 1 if products else 1
    products.append({"id": new_id, "name": name, "stock": stock, "price": price})
    flash('Product added successfully!', 'success')
    return redirect(url_for('list_products'))

@app.route('/sales', methods=['GET', 'POST'])
def sales_page():
    if request.method == 'POST':
        product_id = int(request.form['product_id'])
        qty = int(request.form['qty'])
        
        product = next((p for p in products if p['id'] == product_id), None)
        if not product:
            flash('Product not found!', 'error')
            return redirect(url_for('sales_page'))
        
        if product['stock'] < qty:
            flash(f'Insufficient stock! Available: {product["stock"]}', 'error')
            return redirect(url_for('sales_page'))
        
        product['stock'] -= qty
        total = product['price'] * qty
        sale_id = len(sales) + 1
        sales.append({
            'id': sale_id,
            'product_id': product_id,
            'product_name': product['name'],
            'qty': qty,
            'total': total,
            'timestamp': datetime.now().strftime('%Y-%m-%d %H:%M:%S')
        })
        flash('Sale recorded successfully!', 'success')
        return redirect(url_for('sales_page'))
    
    return render_template('sales.html', products=products, sales_list=sales)

if __name__ == '__main__':
    app.run(debug=True)

